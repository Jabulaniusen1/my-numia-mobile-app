# NUMIA Mobile local environment
# Values prefixed with EXPO_PUBLIC_ are bundled into the mobile app.

# Backend API
# iOS simulator can use localhost. Physical devices should use your Mac LAN IP.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001
EXPO_PUBLIC_API_TIMEOUT_MS=12000

# Solana
EXPO_PUBLIC_SOLANA_NETWORK=devnet
EXPO_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
EXPO_PUBLIC_SOLANA_TIMEOUT_MS=10000
EXPO_PUBLIC_SOLANA_EXPLORER_URL=https://explorer.solana.com

# Price feed
EXPO_PUBLIC_SOLANA_PRICE_API_URL=https://api.coingecko.com/api/v3/simple/price?ids=solana&vs_currencies=usd

# Expo push notifications
EXPO_PUBLIC_EAS_PROJECT_ID=

# SPL token support for future mobile fee payments
EXPO_PUBLIC_USDC_MINT=