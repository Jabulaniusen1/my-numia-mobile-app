# Local backend URL for Expo app
# iOS simulator can use localhost
# Physical devices must use your machine LAN IP, e.g. http://192.168.1.42:3001
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001

# Optional: Solana RPC used for wallet balance on dashboard
EXPO_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Optional: SOL/USD price source for dashboard USD conversion
EXPO_PUBLIC_SOLANA_PRICE_API_URL=https://api.coingecko.com/api/v3/simple/price?ids=solana&vs_currencies=usd

# Optional: Solana/price request timeout in milliseconds
EXPO_PUBLIC_SOLANA_TIMEOUT_MS=10000

# Optional: EAS project ID for Expo push tokens
# Needed for reliable push-token generation in development builds.
EXPO_PUBLIC_EAS_PROJECT_ID=
